        {
          "elementId"    :"ch01-el22",
          "type"         :"text",
          "subtype"      :"bridge",
          "format"       :"HTML",
          "text"         :"Believers are secure in God’s love and keeping — but that security does not lead to passivity. It leads to action. We are called to hold firmly to the truth and to guard it carefully.<br><br>The Christian life is not just about believing the gospel — it is also about contending for it when it is challenged or distorted.",
          "bottomPadding":"normal"
        },

        {
          "elementId"    :"ch01-el23",
          "type"         :"heading",
