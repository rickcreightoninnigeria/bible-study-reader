        },

        {
          "elementId"    :"ch01-el08",
          "type"         :"text",
          "subtype"      :"bridge",
          "format"       :"HTML",
          "text"         :"Even before addressing challenges, Jude reminds believers of their identity. We are secure because of God’s calling, love, and preserving power.",
