          "format"       :"plainText",
          "text"         :"Read Jude 3",
          "bottomPadding":"normal"
        },

        {
          "elementId"    :"ch01-el10",
          "type"         :"text",
          "subtype"      :"bridge",
          "format"       :"HTML",
          "text"         :"Jude had originally intended to write a different kind of letter — but something urgent changed his plans.",
          "bottomPadding":"normal"
