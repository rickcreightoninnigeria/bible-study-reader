        {
          "elementId"    :"ch01-el20",
          "type"         :"text",
          "subtype"      :"bridge",
          "format"       :"HTML",
          "text"         :"False teaching often distorts grace — turning it into permission to sin rather than a reason to live for God. Jude warns that this is not a small issue; it strikes at the heart of the gospel.",
          "bottomPadding":"normal"
        },

        {
          "elementId"    :"ch01-el21",
          "type"         :"heading",
          "subtype"      :"subsection",
          "level"        :"2",
          "format"       :"plainText",
          "text"         :"Conclusion",
          "bottomPadding":"normal"
